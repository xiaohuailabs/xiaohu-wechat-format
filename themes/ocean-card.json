{
  "name": "静谧卡片",
  "description": "深海蔚蓝 #4a7c9b 强调，淡蓝底+卡片布局+网格纹理+深海阴影，适合技术文章、商业分析",
  "colors": {
    "primary": "#3a4150",
    "accent": "#4a7c9b",
    "background": "#f0f4f8",
    "blockquote_bg": "#e8f0f8",
    "code_bg": "#3B3B3B",
    "hr_color": "#4a7c9b",
    "footnote_bg": "rgba(74,124,155,0.04)"
  },
  "styles": {
    "wrapper": {
      "background_color": "#f0f4f8",
      "padding": "16px"
    },
    "h1": {
      "font_size": "22px",
      "font_weight": "bold",
      "color": "#3a4150",
      "text_align": "center",
      "padding": "16px 24px",
      "margin_top": "0",
      "margin_bottom": "12px",
      "line_height": "1.3",
      "border_bottom": "1px dashed rgba(58,65,80,0.3)"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "bold",
      "color": "#4a7c9b",
      "border_bottom": "1px dashed rgba(58,65,80,0.3)",
      "padding": "0 0 10px 0",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "line_height": "1.3"
    },
    "h3": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#4a7c9b",
      "border_bottom": "2px solid #4a7c9b",
      "padding": "0 0 6px 0",
      "margin_top": "28px",
      "margin_bottom": "12px",
      "line_height": "1.3",
      "display": "inline-block"
    },
    "p": {
      "font_size": "15px",
      "color": "#3a4150",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.5px",
      "text_align": "justify"
    },
    "blockquote": {
      "border_left": "5px solid #4a7c9b",
      "background": "#e8f0f8",
      "padding": "15px 20px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "border_radius": "0 12px 12px 0",
      "font_size": "15px",
      "color": "#3a4150",
      "line_height": "1.75",
      "font_style": "italic",
      "box_shadow": "inset 0 0 15px rgba(74,124,155,0.1)"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#3a4150",
      "line_height": "1.75",
      "margin_bottom": "0",
      "letter_spacing": "0.3px",
      "font_style": "normal",
      "background": "transparent"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#3d6a8a"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "#4a7c9b",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "12px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(74,124,155,0.15)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "14px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "1px",
      "background": "rgba(58,65,80,0.1)",
      "border": "none"
    },
    "code": {
      "background": "rgba(74,124,155,0.1)",
      "padding": "3px 6px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "#3d6a8a",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#f0f4f8",
      "border_radius": "12px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "border_top": "3px solid #4a7c9b",
      "box_shadow": "0 4px 12px rgba(74,124,155,0.1)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#e0e5ec"
    },
    "pre": {
      "background": "#f0f4f8",
      "color": "#3a4150",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#3a4150",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "12px",
      "overflow": "hidden",
      "box_shadow": "0 2px 8px rgba(74,124,155,0.08)"
    },
    "th": {
      "background": "rgba(74,124,155,0.06)",
      "padding": "10px 12px",
      "border": "1px solid rgba(58,65,80,0.1)",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#3a4150"
    },
    "td": {
      "padding": "10px 12px",
      "border": "1px solid rgba(58,65,80,0.1)",
      "color": "#3a4150"
    },
    "list_item_bullet": {
      "color": "#4a7c9b",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(74,124,155,0.12)",
      "color": "#4a7c9b",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#3a4150",
      "line_height": "1.75",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed rgba(58,65,80,0.2)"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#4a7c9b",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "linear-gradient(135deg, #e8f0f8, #eef3fa)",
      "border": "2px solid #4a7c9b",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "12px"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#3d6a8a",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#3a4150",
      "line_height": "1.8",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "17px",
      "font_weight": "bold",
      "color": "#3d6a8a",
      "padding": "0",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "layout": "card",
  "card": {
    "bg": "#f0f4f8",
    "card_bg": "#ffffff",
    "card_texture": "linear-gradient(rgba(74,124,155,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(74,124,155,0.03) 1px, transparent 1px)",
    "card_texture_size": "24px 24px",
    "card_border": "1px solid rgba(74,124,155,0.08)",
    "card_shadow": "0 8px 28px rgba(58,65,80,0.06), 0 0 16px rgba(74,124,155,0.15)",
    "card_radius": "14px"
  }
}